{
  "name": "@mizchi/rlm",
  "version": "0.1.1",
  "private": false,
  "type": "module",
  "description": "RLM (Recursive Language Models) TypeScript prototype",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./cli": {
      "types": "./dist/cli.d.mts",
      "import": "./dist/cli.mjs"
    },
    "./package.json": "./package.json"
  },
  "bin": "rlm",
  "files": [
    "rlm",
    "dist",
    "README.md",
    "docs",
    "LICENSE*"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown src/index.ts src/cli.ts --format esm --dts --out-dir dist --clean",
    "prepack": "pnpm run build",
    "release:npm": "npm publish --access public",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "tsc --noEmit",
    "eval": "node scripts/eval.ts --provider mock --cases eval/cases.sample.jsonl --profile hybrid",
    "eval:pure": "node scripts/eval.ts --provider mock --cases eval/cases.sample.jsonl --profile pure",
    "eval:openai": "node scripts/eval.ts --provider openai --cases eval/cases.sample.jsonl --model gpt-4.1-mini --profile hybrid",
    "eval:openai:pure": "node scripts/eval.ts --provider openai --cases eval/cases.sample.jsonl --model gpt-4.1-mini --profile pure",
    "eval:ablation": "node scripts/eval_ablation.ts --provider mock --cases eval/cases.sample.jsonl --profiles pure,hybrid --runs 3",
    "eval:ablation:openai": "node scripts/eval_ablation.ts --provider openai --cases eval/cases.sample.jsonl --model gpt-4.1-mini --profiles pure,hybrid --runs 2",
    "flatbuffers:longrun": "node scripts/flatbuffers_long_run.ts --planner-provider mock --candidate-limit 3 --max-iterations 2",
    "lint:longrun": "node scripts/lint_long_run.ts --planner-provider mock --candidate-limit 3 --max-iterations 2"
  },
  "devDependencies": {
    "tsdown": "^0.20.3",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
